{
    "name": "redis-vl-typescript",
    "private": true,
    "version": "0.0.1",
    "description": "The AI-native Redis TypeScript/Node.js client for vector operations",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch",
        "test": "vitest run",
        "test:unit": "vitest run tests/unit",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "type-check": "tsc --noEmit",
        "prepare": "husky install",
        "prepublishOnly": "npm run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/booleanhunter/redis-vl-typescript.git"
    },
    "keywords": [
        "redis",
        "redis-vl",
        "vector-database",
        "typescript",
        "nodejs",
        "semantic-caching",
        "semantic-routing"
    ],
    "license": "MIT",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "dependencies": {
        "redis": "^5.10.0"
    },
    "devDependencies": {
        "@types/node": "^25.0.9",
        "@typescript-eslint/eslint-plugin": "^8.53.0",
        "@typescript-eslint/parser": "^8.53.0",
        "@vitest/coverage-v8": "^4.0.17",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.17"
    }
}
